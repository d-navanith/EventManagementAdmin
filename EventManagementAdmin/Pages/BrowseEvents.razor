@page "/BrowseEvents"
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Browse Events - Admin Panel</PageTitle>

<div class="container animate-fade-in">
    <div class="page-header">
        <div class="page-icon" style="background: linear-gradient(135deg, rgba(72, 173, 252, 0.1), rgba(72, 173, 252, 0.2)); color: #48adfc;">
            <i class="bi bi-calendar-event-fill"></i>
        </div>
        <div>
            <h2>Campus Events</h2>
            <small class="text-muted">View all campus events as they appear to students</small>
        </div>
    </div>

    <!-- Filter Section -->
    <div class="card mb-4">
        <div class="card-body py-3">
            <div class="row align-items-end">
                <div class="col-md-4 mb-2 mb-md-0">
                    <label class="form-label"><i class="bi bi-funnel me-1"></i>Filter by Category</label>
                    <select class="form-select" @bind="selectedCategory">
                        <option value="">All Categories</option>
                        <option value="Workshop">Workshop</option>
                        <option value="Seminar">Seminar</option>
                        <option value="Sports">Sports</option>
                        <option value="Social">Social</option>
                        <option value="Academic">Academic</option>
                        <option value="Cultural">Cultural</option>
                    </select>
                </div>
                <div class="col-md-4 mb-2 mb-md-0">
                    <label class="form-label"><i class="bi bi-search me-1"></i>Search Events</label>
                    <input type="text" class="form-control" placeholder="Search by title..." @bind="searchTerm" @bind:event="oninput" />
                </div>
                <div class="col-md-4 d-flex align-items-end gap-2">
                    <button class="btn btn-outline-secondary" @onclick="ClearFilters">
                        <i class="bi bi-x-circle me-1"></i>Clear
                    </button>
                    <button class="btn btn-outline-primary" @onclick="LoadData">
                        <i class="bi bi-arrow-clockwise me-1"></i>Refresh
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center my-5">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2 text-muted">Fetching events from database...</p>
        </div>
    }
    else if (!FilteredEvents.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-calendar-x" style="font-size: 3rem; color: #dee2e6;"></i>
            <h5 class="mt-3 text-muted">No Events Found</h5>
            <p class="text-muted">Try adjusting your filters or check back later for new events.</p>
        </div>
    }
    else
    {
        <p class="text-muted mb-3"><small>Showing @FilteredEvents.Count of @events.Count events</small></p>
        <div class="row">
            @foreach (var item in FilteredEvents)
            {
                <div class="col-md-4 mb-4">
                    <div class="card event-card h-100">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <div class="event-image-container" @onclick="() => ViewImageFullScreen(item.ImageUrl, item.Title)" role="button" title="Click to view full image">
                                <img class="card-img-top" src="@item.ImageUrl"
                                     style="height:200px; object-fit:contain; background:#f8f9fa; padding:8px;" alt="@item.Title" />
                                <div class="image-overlay">
                                    <i class="bi bi-arrows-fullscreen"></i>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="event-placeholder @item.Category.ToLower()">
                                <span>@GetCategoryEmoji(item.Category)</span>
                            </div>
                        }
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title mb-0" style="font-size: 1.05rem;">@item.Title</h5>
                                <span class="badge @GetStatusBadgeClass(item.Status)">@item.Status</span>
                            </div>
                            <div class="mb-2">
                                <small class="text-muted d-block mb-1">
                                    <i class="bi bi-geo-alt me-1"></i>@item.Location
                                </small>
                                <small class="text-muted d-block mb-1">
                                    <i class="bi bi-calendar3 me-1"></i>@item.Date at @item.Time
                                </small>
                                <small class="text-muted d-block mb-1">
                                    <i class="bi bi-tag me-1"></i>@item.Category
                                </small>
                                <small class="text-muted d-block">
                                    <i class="bi bi-person me-1"></i>@item.Organizer
                                </small>
                                @if (item.MaxAttendees > 0)
                                {
                                    <small class="text-muted d-block">
                                        <i class="bi bi-people me-1"></i>Max: @item.MaxAttendees attendees
                                    </small>
                                }
                            </div>
                            <p class="card-text small text-muted flex-grow-1">@TruncateDescription(item.Description)</p>
                            <div class="d-flex gap-2 mt-auto pt-3 border-top" style="border-color: rgba(0,0,0,0.06) !important;">
                                <button class="btn btn-sm btn-outline-primary flex-fill"
                                        @onclick="() => ViewDetails(item.Id)">
                                    <i class="bi bi-eye me-1"></i>Details
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert alert-info mt-3">
            <i class="bi bi-info-circle me-2"></i>@statusMessage
        </div>
    }
</div>

<!-- Event Details Modal -->
@if (showDetailsModal && selectedEvent != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">@selectedEvent.Title</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(selectedEvent.ImageUrl))
                    {
                        <div class="text-center mb-3" style="background:#f8f9fa; border-radius:12px; padding:12px;">
                            <img src="@selectedEvent.ImageUrl" class="img-fluid rounded"
                                 style="max-height:400px; max-width:100%; object-fit:contain; cursor:pointer;"
                                 alt="@selectedEvent.Title"
                                 @onclick="() => ViewImageFullScreen(selectedEvent.ImageUrl, selectedEvent.Title)"
                                 title="Click to view full image" />
                        </div>
                    }
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <i class="bi bi-geo-alt-fill text-primary"></i>
                                <div>
                                    <small class="text-muted d-block">Location</small>
                                    <span class="fw-medium">@selectedEvent.Location</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <i class="bi bi-calendar-event-fill text-primary"></i>
                                <div>
                                    <small class="text-muted d-block">Date</small>
                                    <span class="fw-medium">@selectedEvent.Date</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <i class="bi bi-clock-fill text-primary"></i>
                                <div>
                                    <small class="text-muted d-block">Time</small>
                                    <span class="fw-medium">@selectedEvent.Time</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <i class="bi bi-tag-fill text-primary"></i>
                                <div>
                                    <small class="text-muted d-block">Category</small>
                                    <span class="badge bg-info">@selectedEvent.Category</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <i class="bi bi-person-fill text-primary"></i>
                                <div>
                                    <small class="text-muted d-block">Organizer</small>
                                    <span class="fw-medium">@selectedEvent.Organizer</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <i class="bi bi-people-fill text-primary"></i>
                                <div>
                                    <small class="text-muted d-block">Max Attendees</small>
                                    <span class="fw-medium">@(selectedEvent.MaxAttendees > 0 ? selectedEvent.MaxAttendees.ToString() : "Unlimited")</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <i class="bi bi-flag-fill text-primary"></i>
                                <div>
                                    <small class="text-muted d-block">Status</small>
                                    <span class="badge @GetStatusBadgeClass(selectedEvent.Status)">@selectedEvent.Status</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <hr style="opacity: 0.1;" />
                    <h6 class="fw-bold">Description</h6>
                    <div class="text-muted rich-editor-content" style="border:none; min-height:auto; max-height:none; padding:0;">@((MarkupString)(selectedEvent.Description ?? ""))</div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" @onclick="CloseModal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Image Fullscreen Modal -->
@if (showImageModal && !string.IsNullOrEmpty(fullScreenImageUrl))
{
    <div class="modal fade show d-block" tabindex="-1"
         style="background-color: rgba(0,0,0,0.9); z-index:9999;"
         @onclick="CloseImageModal">
        <div class="d-flex flex-column justify-content-center align-items-center" style="min-height:100vh; padding:20px;">
            <button type="button" class="btn btn-outline-light btn-sm position-fixed" style="top:20px; right:20px; z-index:10000; border-radius:50%; width:40px; height:40px;"
                    @onclick="CloseImageModal">
                <i class="bi bi-x-lg"></i>
            </button>
            <h6 class="text-white mb-3">@fullScreenImageTitle</h6>
            <img src="@fullScreenImageUrl" class="img-fluid"
                 style="max-height:85vh; max-width:95vw; object-fit:contain; border-radius:12px; box-shadow: 0 20px 60px rgba(0,0,0,0.5);"
                 alt="@fullScreenImageTitle"
                 @onclick:stopPropagation="true" />
        </div>
    </div>
}

@code {
    private List<EventViewModel> events = new();
    private bool isLoading = true;
    private string statusMessage = "";
    private string selectedCategory = "";
    private string searchTerm = "";
    private bool showDetailsModal = false;
    private EventViewModel? selectedEvent = null;

    // Image fullscreen modal
    private bool showImageModal = false;
    private string fullScreenImageUrl = "";
    private string fullScreenImageTitle = "";

    private List<EventViewModel> FilteredEvents => events.Where(e =>
        (string.IsNullOrEmpty(selectedCategory) || e.Category == selectedCategory) &&
        (string.IsNullOrEmpty(searchTerm) || e.Title.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
    ).ToList();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadData();
            StateHasChanged();
        }
    }

    private async Task LoadData()
    {
        isLoading = true;
        statusMessage = "";
        try
        {
            events = await JS.InvokeAsync<List<EventViewModel>>("firebaseInterop.getEvents");
            if (events == null) events = new();
        }
        catch (Exception ex)
        {
            statusMessage = "Error loading events: " + ex.Message;
            events = new();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ViewDetails(string id)
    {
        selectedEvent = events.FirstOrDefault(e => e.Id == id);
        showDetailsModal = true;
    }

    private void CloseModal()
    {
        showDetailsModal = false;
        selectedEvent = null;
    }

    private void ViewImageFullScreen(string imageUrl, string title)
    {
        fullScreenImageUrl = imageUrl;
        fullScreenImageTitle = title;
        showImageModal = true;
    }

    private void CloseImageModal()
    {
        showImageModal = false;
        fullScreenImageUrl = "";
        fullScreenImageTitle = "";
    }

    private void ClearFilters()
    {
        selectedCategory = "";
        searchTerm = "";
    }

    private string TruncateDescription(string description)
    {
        if (string.IsNullOrEmpty(description)) return "";
        // Strip HTML tags for card preview
        var plainText = System.Text.RegularExpressions.Regex.Replace(description, "<[^>]*>", "").Trim();
        return plainText.Length > 100 ? plainText.Substring(0, 100) + "..." : plainText;
    }

    private string GetCategoryEmoji(string category)
    {
        return category switch
        {
            "Workshop" => "🔧",
            "Seminar" => "📚",
            "Sports" => "⚽",
            "Social" => "🎉",
            "Academic" => "🎓",
            "Cultural" => "🎭",
            _ => "📅"
        };
    }

    private string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Upcoming" => "bg-primary",
            "Ongoing" => "bg-success",
            "Completed" => "bg-secondary",
            "Cancelled" => "bg-danger",
            _ => "bg-info"
        };
    }
}